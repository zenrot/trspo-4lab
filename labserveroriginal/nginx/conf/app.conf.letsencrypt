server {
    listen 80;
    listen [::]:80;

    server_name ooplabs.ru www.ooplabs.ru admin.ooplabs.ru git.ooplabs.ru my.ooplabs.ru;
    server_tokens off;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}